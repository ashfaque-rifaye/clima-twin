{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "backend/.venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["app.main:app", "--app-dir", "backend", "--port", "8000"],
      "port": 8000
